# Car Events Near Me — environment variables
# Copy to .env.local for local dev, and set these in Vercel for production.

# Stripe (Route A: be the box office, via Stripe Connect).
# Get keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Platform fee taken per booking (e.g. 0.05 = 5%)
PLATFORM_FEE_RATE=0.05

# Database (when you move events off the seed file to Postgres)
# DATABASE_URL=postgres://...
